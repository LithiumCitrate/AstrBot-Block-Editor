          "required": false,
          "default": "",
          "description": "HandlerжҸҸиҝ°пјҲдјҡжҳҫзӨәеңЁеё®еҠ©дёӯпјү"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "и§ҰеҸ‘еҗҺжү§иЎҢзҡ„жөҒзЁӢ"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "дәӢд»¶еҜ№иұЎ"
        },
        "message_str": {
          "type": "string",
          "description": "ж¶ҲжҒҜж–Үжң¬еҶ…е®№"
        },
        "sender_id": {
          "type": "string",
          "description": "еҸ‘йҖҒиҖ…ID"
        },
