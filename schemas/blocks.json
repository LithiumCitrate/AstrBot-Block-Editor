      "code_template": "{% if params.source_type == 'url' %}yield event.image_result({{params.url | render_template}}){% elif params.source_type == 'file' %}yield event.image_result({{params.file_path | render_template}}){% else %}yield event.image_result(self.{{params.variable}}){% endif %}"
    },

    "action.reply_chain": {
      "type": "action",
      "category": "action",
      "display_name": "еӣһеӨҚж¶ҲжҒҜй“ҫ",
      "description": "еӣһеӨҚеҢ…еҗ«еӨҡз§Қз»„д»¶зҡ„ж¶ҲжҒҜй“ҫ",
      "icon": "list",
      "color": "#2196F3",
      "params": {
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "enum",
                "enum": ["text", "image", "at", "at_all", "face", "reply"]
              },
              "content": {
                "type": "string",
                "description": "еҶ…е®№пјҲж–Үжң¬/еӣҫзүҮURL/Atзҡ„QQеҸ·зӯүпјү"
              }
            }
          },
          "required": true,
          "default": [],
          "description": "ж¶ҲжҒҜз»„д»¶еҲ—иЎЁ"
        }
      },
      "inputs": {
        "flow": {
          "type": "flow",
          "required": true
        }
      },
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "з»§з»ӯжү§иЎҢзҡ„жөҒзЁӢ"
        }
      },
      "code_template": "chain = [\n{% for comp in params.components %}{% if comp.type == 'text %}    Comp.Plain({{comp.content | render_template}}),\n{% elif comp.type == 'image' %}    Comp.Image.fromURL({{comp.content | render_template}}),\n{% elif comp.type == 'at' %}    Comp.At(qq={{comp.content}}),\n{% elif comp.type == 'at_all' %}    Comp.AtAll(),\n{% elif comp.type == 'face' %}    Comp.Face(id={{comp.content}}),\n{% endif %}{% endfor %}\n]\nyield event.chain_result(chain)"
    },

    "action.send_message": {
      "type": "action",
      "category": "action",
      "display_name": "дё»еҠЁеҸ‘йҖҒж¶ҲжҒҜ",
      "description": "дё»еҠЁеҗ‘жҢҮе®ҡдјҡиҜқеҸ‘йҖҒж¶ҲжҒҜ",
      "icon": "send",
      "color": "#2196F3",
      "params": {
        "target_type": {
          "type": "enum",
          "enum": ["current", "saved", "specific"],
          "required": true,
          "default": "current",
          "description": "зӣ®ж ҮдјҡиҜқзұ»еһӢ"
        },
        "umo": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "зӣ®ж ҮдјҡиҜқIDпјҲtarget_type=specificж—¶пјү"
        },
        "umo_variable": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "еӯҳеӮЁдјҡиҜқIDзҡ„еҸҳйҮҸеҗҚпјҲtarget_type=savedж—¶пјү"
        },
        "message_type": {
          "type": "enum",
          "enum": ["text", "image", "chain"],
          "required": true,
          "default": "text",
          "description": "ж¶ҲжҒҜзұ»еһӢ"
        },
        "content": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "ж¶ҲжҒҜеҶ…е®№",
          "supports_template": true
        }
      },
      "inputs": {
        "flow": {
          "type": "flow",
          "required": true
        }
      },
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "з»§з»ӯжү§иЎҢзҡ„жөҒзЁӢ"
        }
      },
      "code_template": "{% if params.target_type == 'current' %}umo = event.unified_msg_origin\n{% elif params.target_type == 'saved' %}umo = self.{{params.umo_variable}}\n{% else %}umo = \"{{params.umo}}\"\n{% endif %}\nfrom astrbot.api.event import MessageChain\nchain = MessageChain().message({{params.content | render_template}})\nawait self.context.send_message(umo, chain)"
    },

    "action.http_request": {
      "type": "action",
      "category": "action",
      "display_name": "HTTPиҜ·жұӮ",
      "description": "еҸ‘йҖҒHTTPиҜ·жұӮ",
      "icon": "globe",
      "color": "#2196F3",
      "params": {
        "method": {
          "type": "enum",
          "enum": ["GET", "POST", "PUT", "DELETE"],
          "required": true,
          "default": "GET",
          "description": "иҜ·жұӮж–№жі•"
        },
        "url": {
          "type": "string",
          "required": true,
          "default": "",
          "description": "иҜ·жұӮURL",
          "supports_template": true
        },
        "headers": {
          "type": "object",
          "required": false,
          "default": {},
          "description": "иҜ·жұӮеӨҙ"
        },
        "body": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "иҜ·жұӮдҪ“пјҲPOST/PUTж—¶пјү",
          "supports_template": true
        },
        "timeout": {
          "type": "number",
          "required": false,
          "default": 30,
          "description": "и¶…ж—¶ж—¶й—ҙпјҲз§’пјү"
        },
        "save_to": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "дҝқеӯҳе“Қеә”зҡ„еҸҳйҮҸеҗҚ"
        }
      },
      "inputs": {
        "flow": {
          "type": "flow",
          "required": true
        }
      },
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "з»§з»ӯжү§иЎҢзҡ„жөҒзЁӢ"
        },
        "response": {
          "type": "ref",
          "ref_type": "HttpResponse",
          "description": "е“Қеә”еҜ№иұЎ"
        },
        "status_code": {
          "type": "number",
          "description": "зҠ¶жҖҒз Ғ"
        },
        "body": {
          "type": "string",
          "description": "е“Қеә”дҪ“"
        }
      },
      "code_template": "import aiohttp\nasync with aiohttp.ClientSession() as session:\n    {% if params.method == 'GET' %}\n    async with session.get({{params.url | render_template}}, headers={{params.headers}}, timeout={{params.timeout}}) as resp:\n    {% elif params.method == 'POST' %}\n    async with session.post({{params.url | render_template}}, headers={{params.headers}}, data={{params.body | render_template}}, timeout={{params.timeout}}) as resp:\n    {% elif params.method == 'PUT' %}\n    async with session.put({{params.url | render_template}}, headers={{params.headers}}, data={{params.body | render_template}}, timeout={{params.timeout}}) as resp:\n    {% elif params.method == 'DELETE' %}\n    async with session.delete({{params.url | render_template}}, headers={{params.headers}}, timeout={{params.timeout}}) as resp:\n    {% endif %}\n        {{params.save_to}}_status = resp.status\n        {{params.save_to}}_body = await resp.text()"
    },

    "action.delay": {
      "type": "action",
      "category": "action",
