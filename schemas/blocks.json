{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AstrBot Block Definitions",
  "description": "所有可用行为块的定义",
  "blocks": {
    "trigger.command": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "指令触发",
      "description": "当用户发送指定指令时触发",
      "icon": "terminal",
      "color": "#4CAF50",
      "params": {
        "command": {
          "type": "string",
          "required": true,
          "default": "",
          "description": "指令名称（不含/前缀）",
          "validation": {
            "pattern": "^[a-zA-Z0-9_]+$",
            "message": "指令只能包含字母、数字和下划线"
          }
        },
        "alias": {
          "type": "array",
          "items": "string",
          "required": false,
          "default": [],
          "description": "指令别名列表"
        },
        "description": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "Handler描述（会显示在帮助中）"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "message_str": {
          "type": "string",
          "description": "消息文本内容"
        },
        "sender_id": {
          "type": "string",
          "description": "发送者ID"
        },
        "sender_name": {
          "type": "string",
          "description": "发送者昵称"
        }
      },
      "code_template": "@filter.command(\"{{params.command}}\"{% if params.alias %}, alias={{params.alias}}{% endif %})\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    '''{{params.description}}'''\n    {{handler_body}}"
    },

    "trigger.regex": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "正则触发",
      "description": "使用正则表达式匹配消息",
      "icon": "regex",
      "color": "#4CAF50",
      "params": {
        "pattern": {
          "type": "string",
          "required": true,
          "default": "",
          "description": "正则表达式"
        },
        "description": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "Handler描述"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "匹配后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "match_groups": {
          "type": "array",
          "items": "string",
          "description": "正则捕获组"
        }
      },
      "code_template": "@filter.regex(\"{{params.pattern}}\")\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    '''{{params.description}}'''\n    {{handler_body}}"
    },

    "trigger.keyword": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "关键词触发",
      "description": "当消息包含指定关键词时触发",
      "icon": "key",
      "color": "#4CAF50",
      "params": {
        "keywords": {
          "type": "array",
          "items": "string",
          "required": true,
          "default": [],
          "description": "关键词列表"
        },
        "match_all": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "是否需要匹配所有关键词"
        },
        "case_sensitive": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "是否区分大小写"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "matched_keyword": {
          "type": "string",
          "description": "匹配到的关键词"
        }
      },
      "code_template": "@filter.event_message_type(filter.EventMessageType.ALL)\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    '''关键词触发处理器'''\n    msg = event.message_str{% if not params.case_sensitive %}.lower(){% endif %}\n    keywords = {{params.keywords}}\n    matched = None\n    {% if params.match_all %}\n    if all(kw in msg for kw in keywords):\n        matched = keywords\n    {% else %}\n    for kw in keywords:\n        if kw in msg:\n            matched = kw\n            break\n    {% endif %}\n    if matched:\n        {{handler_body}}"
    },

    "trigger.event_message_type": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "消息类型过滤",
      "description": "按消息类型（群聊/私聊）过滤",
      "icon": "filter",
      "color": "#4CAF50",
      "params": {
        "message_type": {
          "type": "enum",
          "enum": ["ALL", "PRIVATE_MESSAGE", "GROUP_MESSAGE"],
          "required": true,
          "default": "ALL",
          "description": "消息类型"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "is_private": {
          "type": "boolean",
          "description": "是否为私聊"
        }
      },
      "code_template": "@filter.event_message_type(filter.EventMessageType.{{params.message_type}})\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    {{handler_body}}"
    },

    "trigger.platform": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "平台过滤",
      "description": "按消息平台过滤",
      "icon": "platform",
      "color": "#4CAF50",
      "params": {
        "platforms": {
          "type": "array",
          "items": {
            "type": "enum",
            "enum": ["AIOCQHTTP", "QQOFFICIAL", "GEWECHAT", "TELEGRAM", "FEISHU", "DINGTALK", "ALL"]
          },
          "required": true,
          "default": ["ALL"],
          "description": "平台列表"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "platform_name": {
          "type": "string",
          "description": "平台名称"
        }
      },
      "code_template": "@filter.platform_adapter_type({% for p in params.platforms %}filter.PlatformAdapterType.{{p}}{% if not loop.last %} | {% endif %}{% endfor %})\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    {{handler_body}}"
    },

    "trigger.permission": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "权限过滤",
      "description": "按用户权限过滤（管理员/普通用户）",
      "icon": "shield",
      "color": "#4CAF50",
      "params": {
        "permission": {
          "type": "enum",
          "enum": ["ADMIN", "MEMBER"],
          "required": true,
          "default": "ADMIN",
          "description": "权限类型"
        },
        "raise_error": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "无权限时是否提示错误"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        }
      },
      "code_template": "@filter.permission_type(filter.PermissionType.{{params.permission}}, raise_error={{params.raise_error}})\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    {{handler_body}}"
    },

    "trigger.on_loaded": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "Bot加载完成",
      "description": "当AstrBot加载完成时触发",
      "icon": "rocket",
      "color": "#4CAF50",
      "params": {},
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        }
      },
      "code_template": "@filter.on_astrbot_loaded()\nasync def {{handler_name}}(self):\n    {{handler_body}}"
    },

    "trigger.on_llm_request": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "LLM请求钩子",
      "description": "在LLM请求前触发，可修改请求参数",
      "icon": "brain",
      "color": "#4CAF50",
      "params": {},
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "request": {
          "type": "ref",
          "ref_type": "ProviderRequest",
          "description": "请求对象"
        }
      },
      "code_template": "@filter.on_llm_request()\nasync def {{handler_name}}(self, event: AstrMessageEvent, req: ProviderRequest):\n    {{handler_body}}"
    },

    "trigger.user_join": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "用户加入",
      "description": "当有用户加入群聊时触发",
      "icon": "user-plus",
      "color": "#4CAF50",
      "params": {
        "welcome_message": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "欢迎消息（可选，留空则不自动发送）",
          "supports_template": true
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "user_id": {
          "type": "string",
          "description": "加入用户ID"
        },
        "user_name": {
          "type": "string",
          "description": "加入用户昵称"
        },
        "group_id": {
          "type": "string",
          "description": "群ID"
        }
      },
      "code_template": "@filter.on_user_join()\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    {{handler_body}}"
    },

    "trigger.user_leave": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "用户离开",
      "description": "当有用户离开群聊时触发",
      "icon": "user-minus",
      "color": "#4CAF50",
      "params": {
        "goodbye_message": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "告别消息（可选）",
          "supports_template": true
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "user_id": {
          "type": "string",
          "description": "离开用户ID"
        },
        "user_name": {
          "type": "string",
          "description": "离开用户昵称"
        },
        "group_id": {
          "type": "string",
          "description": "群ID"
        }
      },
      "code_template": "@filter.on_user_leave()\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    {{handler_body}}"
    },

    "trigger.file_upload": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "文件上传",
      "description": "当有用户上传文件时触发",
      "icon": "upload",
      "color": "#4CAF50",
      "params": {
        "file_types": {
          "type": "array",
          "items": "string",
          "required": false,
          "default": [],
          "description": "文件类型过滤（如: [\".jpg\", \".png\"]）"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "file_name": {
          "type": "string",
          "description": "文件名"
        },
        "file_url": {
          "type": "string",
          "description": "文件URL"
        },
        "file_size": {
          "type": "number",
          "description": "文件大小（字节）"
        },
        "sender_id": {
          "type": "string",
          "description": "上传者ID"
        }
      },
      "code_template": "@filter.on_file_upload()\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    {{handler_body}}"
    },

    "trigger.reaction": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "表情回应",
      "description": "当用户对消息添加表情回应时触发",
      "icon": "smile",
      "color": "#4CAF50",
      "params": {
        "emojis": {
          "type": "array",
          "items": "string",
          "required": false,
          "default": [],
          "description": "表情过滤（留空则所有表情）"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "emoji": {
          "type": "string",
          "description": "表情符号"
        },
        "message_id": {
          "type": "string",
          "description": "被回应的消息ID"
        },
        "sender_id": {
          "type": "string",
          "description": "回应者ID"
        }
      },
      "code_template": "@filter.on_reaction()\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    {{handler_body}}"
    },

    "trigger.schedule": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "定时触发",
      "description": "按时间计划定时触发",
      "icon": "calendar",
      "color": "#4CAF50",
      "params": {
        "schedule_type": {
          "type": "enum",
          "enum": ["interval", "daily", "weekly", "cron"],
          "required": true,
          "default": "interval",
          "description": "调度类型：interval(间隔)、daily(每日)、weekly(每周)、cron( cron表达式)"
        },
        "interval_seconds": {
          "type": "number",
          "required": false,
          "default": 60,
          "description": "间隔秒数（schedule_type=interval时）"
        },
        "time": {
          "type": "string",
          "required": false,
          "default": "09:00",
          "description": "触发时间 HH:MM（daily/weekly时）"
        },
        "day_of_week": {
          "type": "number",
          "required": false,
          "default": 1,
          "description": "星期几 1-7（weekly时，1=周一）"
        },
        "cron_expression": {
          "type": "string",
          "required": false,
          "default": "0 9 * * *",
          "description": "Cron表达式（cron时）"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "trigger_time": {
          "type": "string",
          "description": "触发时间"
        }
      },
      "code_template": "@filter.on_schedule(schedule_type=\"{{params.schedule_type}}\", {% if params.schedule_type == 'interval' %}interval={{params.interval_seconds}}{% elif params.schedule_type == 'daily' %}time=\"{{params.time}}\"{% elif params.schedule_type == 'weekly' %}time=\"{{params.time}}\", day={{params.day_of_week}}{% else %}cron=\"{{params.cron_expression}}\"{% endif %})\nasync def {{handler_name}}(self):\n    {{handler_body}}"
    },

    "trigger.random_chance": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "随机概率触发",
      "description": "按指定概率随机触发",
      "icon": "percent",
      "color": "#4CAF50",
      "params": {
        "probability": {
          "type": "number",
          "required": true,
          "default": 50,
          "description": "触发概率（0-100）"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "rolled_value": {
          "type": "number",
          "description": "掷出的值（1-100）"
        }
      },
      "code_template": "@filter.event_message_type(filter.EventMessageType.ALL)\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    '''随机概率触发'''\n    import random\n    rolled = random.randint(1, 100)\n    if rolled <= {{params.probability}}:\n        {{handler_body}}"
    },

    "trigger.nth_time": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "第N次触发",
      "description": "每第N次触发时执行",
      "icon": "hash",
      "color": "#4CAF50",
      "params": {
        "n": {
          "type": "number",
          "required": true,
          "default": 5,
          "description": "每N次触发"
        },
        "counter_key": {
          "type": "string",
          "required": false,
          "default": "global",
          "description": "计数器键（不同键独立计数）"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "触发后执行的流程"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "事件对象"
        },
        "current_count": {
          "type": "number",
          "description": "当前计数"
        }
      },
      "code_template": "@filter.event_message_type(filter.EventMessageType.ALL)\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    '''第N次触发'''\n    counter_key = \"{{params.counter_key}}\"\n    if not hasattr(self, '_nth_counter'):\n        self._nth_counter = {}\n    if counter_key not in self._nth_counter:\n        self._nth_counter[counter_key] = 0\n    self._nth_counter[counter_key] += 1\n    if self._nth_counter[counter_key] % {{params.n}} == 0:\n        current_count = self._nth_counter[counter_key]\n        {{handler_body}}"
    },

    "action.reply_text": {
      "type": "action",
      "category": "action",
      "display_name": "回复文本",
      "description": "回复一条纯文本消息",
      "icon": "message",
      "color": "#2196F3",
      "params": {
        "text": {
          "type": "string",
          "required": true,
          "default": "",
          "description": "回复的文本内容",
          "supports_template": true
        }
      },
      "inputs": {
        "flow": {
          "type": "flow",
          "required": true
        }
      },
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "继续执行的流程"
        }
      },
      "code_template": "yield event.plain_result({{params.text | render_template}})"
    },

    "action.reply_image": {
      "type": "action",
      "category": "action",
      "display_name": "回复图片",
      "description": "回复一张图片",
      "icon": "image",
      "color": "#2196F3",
      "params": {
        "source_type": {
          "type": "enum",
          "enum": ["url", "file", "variable"],
          "required": true,
          "default": "url",
          "description": "图片来源类型"
        },
        "url": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "图片URL（source_type=url时）",
          "supports_template": true
        },
        "file_path": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "本地文件路径（source_type=file时）",
          "supports_template": true
        },
        "variable": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "变量名（source_type=variable时）"
        }
      },
      "inputs": {
        "flow": {
          "type": "flow",
          "required": true
        }
      },
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "继续执行的流程"
        }
      },
      "code_template": "{% if params.source_type == 'url' %}yield event.image_result({{params.url | render_template}}){% elif params.source_type == 'file' %}yield event.image_result({{params.file_path | render_template}}){% else %}yield event.image_result(self.{{params.variable}}){% endif %}"
    },

    "action.reply_chain": {
      "type": "action",
      "category": "action",
      "display_name": "回复消息链",
      "description": "回复包含多种组件的消息链",
      "icon": "list",
      "color": "#2196F3",
      "params": {
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "enum",
                "enum": ["text", "image", "at", "at_all", "face", "reply"]
              },
              "content": {
                "type": "string",
                "description": "内容（文本/图片URL/At的QQ号等）"
              }
            }
          },
          "required": true,
          "default": [],
          "description": "消息组件列表"
        }
      },
      "inputs": {
        "flow": {
          "type": "flow",
          "required": true
        }
      },
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "继续执行的流程"
        }
      },
      "code_template": "chain = [\n{% for comp in params.components %}{% if comp.type == 'text %}    Comp.Plain({{comp.content | render_template}}),\n{% elif comp.type == 'image' %}    Comp.Image.fromURL({{comp.content | render_template}}),\n{% elif comp.type == 'at' %}    Comp.At(qq={{comp.content}}),\n{% elif comp.type == 'at_all' %}    Comp.AtAll(),\n{% elif comp.type == 'face' %}    Comp.Face(id={{comp.content}}),\n{% endif %}{% endfor %}\n]\nyield event.chain_result(chain)"
    },

    "action.send_message": {
      "type": "action",
      "category": "action",
      "display_name": "主动发送消息",
      "description": "主动向指定会话发送消息",
      "icon": "send",
      "color": "#2196F3",
      "params": {
        "target_type": {
          "type": "enum",
          "enum": ["current", "saved", "specific"],
          "required": true,
          "default": "current",
          "description": "目标会话类型"
        },
        "umo": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "目标会话ID（target_type=specific时）"
        },
        "umo_variable": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "存储会话ID的变量名（target_type=saved时）"
        },
        "message_type": {
          "type": "enum",
          "enum": ["text", "image", "chain"],
          "required": true,
          "default": "text",
          "description": "消息类型"
        },
        "content": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "消息内容",
          "supports_template": true
        }
      },
      "inputs": {
        "flow": {
          "type": "flow",
          "required": true
        }
      },
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "继续执行的流程"
        }
      },
      "code_template": "{% if params.target_type == 'current' %}umo = event.unified_msg_origin\n{% elif params.target_type == 'saved' %}umo = self.{{params.umo_variable}}\n{% else %}umo = \"{{params.umo}}\"\n{% endif %}\nfrom astrbot.api.event import MessageChain\nchain = MessageChain().message({{params.content | render_template}})\nawait self.context.send_message(umo, chain)"
    },

    "action.http_request": {
      "type": "action",
      "category": "action",
      "display_name": "HTTP请求",
      "description": "发送HTTP请求",
      "icon": "globe",
      "color": "#2196F3",
      "params": {
        "method": {
          "type": "enum",
          "enum": ["GET", "POST", "PUT", "DELETE"],
          "required": true,
          "default": "GET",
          "description": "请求方法"
        },
        "url": {
          "type": "string",
          "required": true,
          "default": "",
          "description": "请求URL",
          "supports_template": true
        },
        "headers": {
          "type": "object",
          "required": false,
          "default": {},
          "description": "请求头"
        },
        "body": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "请求体（POST/PUT时）",
          "supports_template": true
        },
        "timeout": {
          "type": "number",
          "required": false,
          "default": 30,
          "description": "超时时间（秒）"
        },
        "save_to": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "保存响应的变量名"
        }
      },
      "inputs": {
        "flow": {
          "type": "flow",
          "required": true
        }
      },
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "继续执行的流程"
        },
        "response": {
          "type": "ref",
          "ref_type": "HttpResponse",
          "description": "响应对象"
        },
        "status_code": {
          "type": "number",
          "description": "状态码"
        },
        "body": {
          "type": "string",
          "description": "响应体"
        }
      },
      "code_template": "import aiohttp\nasync with aiohttp.ClientSession() as session:\n    {% if params.method == 'GET' %}\n    async with session.get({{params.url | render_template}}, headers={{params.headers}}, timeout={{params.timeout}}) as resp:\n    {% elif params.method == 'POST' %}\n    async with session.post({{params.url | render_template}}, headers={{params.headers}}, data={{params.body | render_template}}, timeout={{params.timeout}}) as resp:\n    {% elif params.method == 'PUT' %}\n    async with session.put({{params.url | render_template}}, headers={{params.headers}}, data={{params.body | render_template}}, timeout={{params.timeout}}) as resp:\n    {% elif params.method == 'DELETE' %}\n    async with session.delete({{params.url | render_template}}, headers={{params.headers}}, timeout={{params.timeout}}) as resp:\n    {% endif %}\n        {{params.save_to}}_status = resp.status\n        {{params.save_to}}_body = await resp.text()"
    },

