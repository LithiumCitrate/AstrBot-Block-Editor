          "required": true,
          "default": "",
          "description": "жӯЈеҲҷиЎЁиҫҫејҸ"
        },
        "description": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "HandlerжҸҸиҝ°"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "еҢ№й…ҚеҗҺжү§иЎҢзҡ„жөҒзЁӢ"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "дәӢд»¶еҜ№иұЎ"
