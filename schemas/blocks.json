          "description": "жӯЈеҲҷжҚ•иҺ·з»„"
        }
      },
      "code_template": "@filter.regex(\"{{params.pattern}}\")\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    '''{{params.description}}'''\n    {{handler_body}}"
    },

    "trigger.keyword": {
      "type": "trigger",
      "category": "trigger",
      "display_name": "е…ій”®иҜҚи§ҰеҸ‘",
      "description": "еҪ“ж¶ҲжҒҜеҢ…еҗ«жҢҮе®ҡе…ій”®иҜҚж—¶и§ҰеҸ‘",
      "icon": "key",
      "color": "#4CAF50",
      "params": {
        "keywords": {
          "type": "array",
          "items": "string",
          "required": true,
          "default": [],
          "description": "е…ій”®иҜҚеҲ—иЎЁ"
        },
        "match_all": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "жҳҜеҗҰйңҖиҰҒеҢ№й…ҚжүҖжңүе…ій”®иҜҚ"
        },
        "case_sensitive": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "жҳҜеҗҰеҢәеҲҶеӨ§е°ҸеҶҷ"
        }
      },
      "inputs": {},
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "и§ҰеҸ‘еҗҺжү§иЎҢзҡ„жөҒзЁӢ"
        },
        "event": {
          "type": "ref",
          "ref_type": "AstrMessageEvent",
          "description": "дәӢд»¶еҜ№иұЎ"
        },
        "matched_keyword": {
          "type": "string",
          "description": "еҢ№й…ҚеҲ°зҡ„е…ій”®иҜҚ"
        }
      },
      "code_template": "@filter.event_message_type(filter.EventMessageType.ALL)\nasync def {{handler_name}}(self, event: AstrMessageEvent):\n    '''е…ій”®иҜҚи§ҰеҸ‘еӨ„зҗҶеҷЁ'''\n    msg = event.message_str{% if not params.case_sensitive %}.lower(){% endif %}\n    keywords = {{params.keywords}}\n    matched = None\n    {% if params.match_all %}\n    if all(kw in msg for kw in keywords):\n        matched = keywords\n    {% else %}\n    for kw in keywords:\n        if kw in msg:\n            matched = kw\n            break\n    {% endif %}\n    if matched:\n        {{handler_body}}"
    },

