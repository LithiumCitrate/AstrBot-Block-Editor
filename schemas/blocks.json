    "action.reply_image": {
      "type": "action",
      "category": "action",
      "display_name": "еӣһеӨҚеӣҫзүҮ",
      "description": "еӣһеӨҚдёҖеј еӣҫзүҮ",
      "icon": "image",
      "color": "#2196F3",
      "params": {
        "source_type": {
          "type": "enum",
          "enum": ["url", "file", "variable"],
          "required": true,
          "default": "url",
          "description": "еӣҫзүҮжқҘжәҗзұ»еһӢ"
        },
        "url": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "еӣҫзүҮURLпјҲsource_type=urlж—¶пјү",
          "supports_template": true
        },
        "file_path": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "жң¬ең°ж–Үд»¶и·Ҝеҫ„пјҲsource_type=fileж—¶пјү",
          "supports_template": true
        },
        "variable": {
          "type": "string",
          "required": false,
          "default": "",
          "description": "еҸҳйҮҸеҗҚпјҲsource_type=variableж—¶пјү"
        }
      },
      "inputs": {
        "flow": {
          "type": "flow",
          "required": true
        }
      },
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "з»§з»ӯжү§иЎҢзҡ„жөҒзЁӢ"
        }
