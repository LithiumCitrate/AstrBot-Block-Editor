      "code_template": "{% if params.operation == 'set' %}self.{{params.name}} = {{params.value | render_template}}{% elif params.operation == 'get' %}_var_{{params.name}} = self.{{params.name}}{% elif params.operation == 'increment' %}self.{{params.name}} = self.{{params.name}} + 1{% elif params.operation == 'decrement' %}self.{{params.name}} = self.{{params.name}} - 1{% elif params.operation == 'append' %}self.{{params.name}}.append({{params.value | render_template}}){% endif %}"
    },

    "util.log": {
      "type": "util",
      "category": "util",
      "display_name": "日志输出",
      "description": "输出日志信息",
      "icon": "file-text",
      "color": "#9C27B0",
      "params": {
        "level": {
          "type": "enum",
          "enum": ["debug", "info", "warning", "error"],
          "required": true,
          "default": "info",
          "description": "日志级别"
        },
        "message": {
          "type": "string",
          "required": true,
          "default": "",
          "description": "日志内容",
          "supports_template": true
        }
      },
      "inputs": {
        "flow": {
          "type": "flow",
          "required": true
        }
      },
      "outputs": {
        "flow": {
          "type": "flow",
          "description": "继续执行的流程"
        }
      },
      "code_template": "logger.{{params.level}}({{params.message | render_template}})"
    }
  }
}
